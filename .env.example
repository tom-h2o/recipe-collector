# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key — used by /api functions only, never exposed to the browser
# Find in: Supabase dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_KEY=eyJ...

# ── Gemini ────────────────────────────────────────────────────────────────────
# Get keys from: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Get DSN from: Sentry dashboard → Project → Settings → Client Keys (DSN)
# Leave blank to disable error tracking in development
VITE_SENTRY_DSN=
SENTRY_DSN=
VITE_APP_ENV=development

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Restrict /api endpoints to a specific origin. Defaults to * if unset.
# ALLOWED_ORIGIN=https://yourdomain.vercel.app
